<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MembreController" padding="12">
    <center>
        <TableView fx:id="tableView" prefWidth="760">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                <TableColumn fx:id="nomColumn" text="Nom" prefWidth="240"/>
                <TableColumn fx:id="emailColumn" text="Email" prefWidth="260"/>
                <TableColumn fx:id="telephoneColumn" text="Téléphone" prefWidth="170"/>
                <TableColumn fx:id="dateColumn" text="Date inscription" prefWidth="180"/>
            </columns>
        </TableView>
    </center>
    <right>
        <VBox spacing="10" prefWidth="320" padding="10">
            <Label text="Informations du membre" />
            <GridPane hgap="10" vgap="10">
                <Label text="Nom" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <TextField fx:id="nomField" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                <Label text="Email" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <TextField fx:id="emailField" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                <Label text="Téléphone" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextField fx:id="telephoneField" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                <Label text="Date inscription" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <TextField fx:id="dateInscriptionField" GridPane.rowIndex="3" GridPane.columnIndex="1" />
            </GridPane>
        </VBox>
    </right>
    <bottom>
        <HBox spacing="10" padding="10">
            <Button text="Ajouter" onAction="#addMembre" />
            <Button text="Modifier" onAction="#updateMembre" />
            <Button text="Supprimer" onAction="#deleteMembre" />
        </HBox>
    </bottom>
</BorderPane>
