<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MembreController">
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>
    <center>
        <TableView fx:id="tableView" prefWidth="760">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                <TableColumn fx:id="nomColumn" text="Nom" prefWidth="180"/>
                <TableColumn fx:id="emailColumn" text="Email" prefWidth="220"/>
                <TableColumn fx:id="telephoneColumn" text="Téléphone" prefWidth="140"/>
                <TableColumn fx:id="adresseColumn" text="Adresse" prefWidth="180"/>
                <TableColumn fx:id="dateNaissanceColumn" text="Date naissance" prefWidth="140"/>
                <TableColumn fx:id="dateInscriptionColumn" text="Date inscription" prefWidth="140"/>
                <TableColumn fx:id="typeAdherentColumn" text="Type" prefWidth="120"/>
                <TableColumn fx:id="statutColumn" text="Statut" prefWidth="100"/>
            </columns>
        </TableView>
    </center>
    <right>
        <VBox spacing="10" prefWidth="320">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label text="Informations du membre" />
            <GridPane hgap="10" vgap="10">
                <Label text="Nom" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <TextField fx:id="nomField" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                <Label text="Email" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <TextField fx:id="emailField" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                <Label text="Téléphone" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextField fx:id="telephoneField" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                <Label text="Adresse" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <TextField fx:id="adresseField" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                <Label text="Date naissance" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                <DatePicker fx:id="dateNaissancePicker" GridPane.rowIndex="4" GridPane.columnIndex="1" />
                <Label text="Date inscription" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                <DatePicker fx:id="dateInscriptionPicker" GridPane.rowIndex="5" GridPane.columnIndex="1" />
                <Label text="Type adhérent" GridPane.rowIndex="6" GridPane.columnIndex="0" />
                <TextField fx:id="typeAdherentField" GridPane.rowIndex="6" GridPane.columnIndex="1" />
                <Label text="Statut" GridPane.rowIndex="7" GridPane.columnIndex="0" />
                <TextField fx:id="statutField" GridPane.rowIndex="7" GridPane.columnIndex="1" />
            </GridPane>
        </VBox>
    </right>
    <bottom>
        <HBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Button text="Ajouter" onAction="#addMembre" />
            <Button text="Modifier" onAction="#updateMembre" />
            <Button text="Supprimer" onAction="#deleteMembre" />
        </HBox>
    </bottom>
</BorderPane>
