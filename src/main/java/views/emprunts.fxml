<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.EmpruntController">
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>
    <center>
        <TableView fx:id="tableView" prefWidth="760">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                <TableColumn fx:id="livreColumn" text="Livre" prefWidth="260"/>
                <TableColumn fx:id="membreColumn" text="Membre" prefWidth="260"/>
                <TableColumn fx:id="dateEmpruntColumn" text="Date emprunt" prefWidth="120"/>
                <TableColumn fx:id="dateRetourPrevueColumn" text="Date retour prévue" prefWidth="140"/>
                <TableColumn fx:id="dateRetourColumn" text="Date retour" prefWidth="140"/>
                <TableColumn fx:id="statutColumn" text="Statut" prefWidth="100"/>
            </columns>
        </TableView>
    </center>
    <right>
        <VBox spacing="10" prefWidth="320">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label text="Nouvel emprunt" />
            <GridPane hgap="10" vgap="10">
                <Label text="Livre" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <ComboBox fx:id="livreComboBox" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                <Label text="Membre" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <ComboBox fx:id="membreComboBox" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                <Label text="Date emprunt" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <DatePicker fx:id="dateEmpruntPicker" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                <Label text="Date retour prévue" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <DatePicker fx:id="dateRetourPrevuePicker" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                <Label text="Notes" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                <TextField fx:id="notesField" GridPane.rowIndex="4" GridPane.columnIndex="1" />
            </GridPane>
        </VBox>
    </right>
    <bottom>
        <HBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Button text="Emprunter" onAction="#addEmprunt" />
            <Button text="Retourner" onAction="#returnEmprunt" />
            <Button text="Supprimer" onAction="#deleteEmprunt" />
            <Button text="Rafraîchir" onAction="#refreshEmprunts" />
        </HBox>
    </bottom>
</BorderPane>
