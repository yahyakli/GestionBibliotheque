<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LivreController">
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>
    <center>
        <TableView fx:id="tableView" prefWidth="760">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                <TableColumn fx:id="titreColumn" text="Titre" prefWidth="220"/>
                <TableColumn fx:id="auteurColumn" text="Auteur" prefWidth="180"/>
                <TableColumn fx:id="categorieColumn" text="Catégorie" prefWidth="140"/>
                <TableColumn fx:id="isbnColumn" text="ISBN" prefWidth="120"/>
                <TableColumn fx:id="editeurColumn" text="Éditeur" prefWidth="140"/>
                <TableColumn fx:id="datePublicationColumn" text="Date publication" prefWidth="140"/>
                <TableColumn fx:id="emplacementColumn" text="Emplacement" prefWidth="120"/>
                <TableColumn fx:id="quantiteColumn" text="Quantité" prefWidth="80"/>
            </columns>
        </TableView>
    </center>
    <right>
        <VBox spacing="10" prefWidth="320">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label text="Informations du livre" />
            <GridPane hgap="10" vgap="10">
                <Label text="Titre" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <TextField fx:id="titreField" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                <Label text="Auteur" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <TextField fx:id="auteurField" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                <Label text="Catégorie" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextField fx:id="categorieField" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                <Label text="ISBN" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <TextField fx:id="isbnField" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                <Label text="Éditeur" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                <TextField fx:id="editeurField" GridPane.rowIndex="4" GridPane.columnIndex="1" />
                <Label text="Date publication" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                <DatePicker fx:id="datePublicationPicker" GridPane.rowIndex="5" GridPane.columnIndex="1" />
                <Label text="Emplacement" GridPane.rowIndex="6" GridPane.columnIndex="0" />
                <TextField fx:id="emplacementField" GridPane.rowIndex="6" GridPane.columnIndex="1" />
                <Label text="Quantité" GridPane.rowIndex="7" GridPane.columnIndex="0" />
                <TextField fx:id="quantiteField" GridPane.rowIndex="7" GridPane.columnIndex="1" />
            </GridPane>
        </VBox>
    </right>
    <bottom>
        <HBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Button text="Ajouter" onAction="#addLivre" />
            <Button text="Modifier" onAction="#updateLivre" />
            <Button text="Supprimer" onAction="#deleteLivre" />
        </HBox>
    </bottom>
</BorderPane>
